APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000
# For Vercel production, set APP_URL to your public domain, e.g. https://manake.vercel.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional Vercel-safe runtime overrides
VERCEL_SESSION_DRIVER=cookie
VERCEL_CACHE_STORE=array
VERCEL_QUEUE_CONNECTION=sync
VERCEL_LOG_CHANNEL=stderr

# Local default
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=manake_db
DB_USERNAME=root
DB_PASSWORD=

# Optional unified PostgreSQL URL (Laravel / generic platforms)
DB_URL=

# Vercel Postgres/Supabase integration variables (auto-detected by config/database.php)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional source MySQL (dipakai command db:copy-mysql-to-supabase)
MYSQL_SOURCE_DB_URL=
MYSQL_SOURCE_DB_HOST=127.0.0.1
MYSQL_SOURCE_DB_PORT=3306
MYSQL_SOURCE_DB_DATABASE=manake_db
MYSQL_SOURCE_DB_USERNAME=root
MYSQL_SOURCE_DB_PASSWORD=
MYSQL_SOURCE_DB_SOCKET=
MYSQL_SOURCE_DB_CHARSET=utf8mb4
MYSQL_SOURCE_DB_COLLATION=utf8mb4_unicode_ci
MYSQL_SOURCE_ATTR_SSL_CA=

# Optional target Supabase/PostgreSQL (dipakai command db:copy-mysql-to-supabase)
SUPABASE_DB_URL=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_CHARSET=utf8
SUPABASE_DB_SCHEMA=public
SUPABASE_DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_SECONDS=300
OTP_REQUIRED=false
OTP_TTL_MINUTES=5
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_LOCKOUT_MINUTES=60
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RESEND_MAX_PER_HOUR=5
PHONE_OTP_TTL_MINUTES=5
PHONE_OTP_MAX_ATTEMPTS=5
PHONE_OTP_RESEND_COOLDOWN_SECONDS=60
PHONE_OTP_RESEND_MAX_PER_HOUR=5
EMAIL_VERIFY_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFY_RESEND_MAX_PER_HOUR=5

SUPER_ADMIN_EMAIL=
SUPERADMIN_EMAIL=
SUPER_ADMIN_NAME=
SUPER_ADMIN_PASSWORD_HASH=
SUPERADMIN_PASSWORD_HASH=

ADMIN_DB_EDIT_ENABLED=false
ADMIN_DB_PAGE_SIZE=25

# Optional monitoring
SENTRY_LARAVEL_DSN=
BUGSNAG_API_KEY=
