APP_NAME=Manake
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=supabase
DB_URL=${SUPABASE_DB_URL}
DB_SSLMODE=require

SUPABASE_DB_URL=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_CHARSET=utf8
SUPABASE_DB_SCHEMA=public
SUPABASE_DB_SSLMODE=require

SINGAPORE_BACKUP_DB_URL=
SINGAPORE_BACKUP_SSH_HOST=152.69.218.198
SINGAPORE_BACKUP_SSH_USER=ubuntu
SINGAPORE_BACKUP_SSH_KEY=~/.ssh/manake_singapore
SINGAPORE_BACKUP_SSH_DB_PORT=5433
SINGAPORE_BACKUP_DB_HOST=
SINGAPORE_BACKUP_DB_PORT=5432
SINGAPORE_BACKUP_DB_DATABASE=manake_backup
SINGAPORE_BACKUP_DB_USERNAME=postgres
SINGAPORE_BACKUP_DB_PASSWORD=
SINGAPORE_BACKUP_DB_CHARSET=utf8
SINGAPORE_BACKUP_DB_SCHEMA=public
SINGAPORE_BACKUP_DB_SSLMODE=require

MYSQL_SOURCE_DB_URL=
MYSQL_SOURCE_DB_HOST=
MYSQL_SOURCE_DB_PORT=3306
MYSQL_SOURCE_DB_DATABASE=
MYSQL_SOURCE_DB_USERNAME=
MYSQL_SOURCE_DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
EQUIPMENT_PLACEHOLDER_URL=/assets/public/MANAKE-FAV-M.png

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Midtrans Configuration
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"


# Ollama AI Configuration
OLLAMA_BASE_URL=http://152.69.218.198:11434
OLLAMA_MODEL=qwen2:0.5b
OLLAMA_TIMEOUT=8

# Gemini AI fallback. Set this in Vercel/env only; never commit a real key.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=12

# Admin & Super Admin Configuration
ADMIN_SYNC_FROM_USERS=false
ADMIN_DB_EDIT_ENABLED=false
SUPERADMIN_EMAIL=admin@manake.id
# SUPERADMIN_PASSWORD is only for local development/demo. For production/tugas akhir, use SUPERADMIN_PASSWORD_HASH instead.
# e.g. php artisan bcrypt "mypassword"
SUPERADMIN_PASSWORD=supersecure123
SUPERADMIN_PASSWORD_HASH=

# Debug Security (Avoid stack trace leaks on Production)
APP_DEBUG=false
MANAKE_ALLOW_PRODUCTION_DEBUG=false
DEBUG_KEY=

