{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "regions": ["sin1"],
    "alias": ["manake"],
    "git": {
        "deploymentEnabled": {
            "main": true
        }
    },
    "outputDirectory": "public/build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt|MANAKE-FAV-M\\.png|MANAKE-FAV-M-white\\.png|manake-logo-blue\\.png|manake-logo-white\\.png)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
