{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "regions": ["sin1"],
    "alias": ["www.manake.app", "manake.app"],
    "git": {
        "deploymentEnabled": {
            "main": true
        }
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0",
            "includeFiles": "{public/build/**,public/images/**,storage/app/public/**,public/storage/**}"
        }
    },
    "redirects": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "manake.vercel.app"
                }
            ],
            "destination": "https://www.manake.app/$1",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "manake.app"
                }
            ],
            "destination": "https://www.manake.app/$1",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/storage/(.*)",
            "destination": "/public/storage/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/public/images/$1"
        },
        {
            "source": "/(favicon\\.ico|robots\\.txt|MANAKE-FAV-M\\.png|MANAKE-FAV-M-white\\.png|manake-logo-blue\\.png|manake-logo-white\\.png)",
            "destination": "/public/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ]
}
